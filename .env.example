# Kopier denne filen til ".env.local" og fyll inn ekte verdier der.
# ".env.local" skal ALDRI deles, limes inn i chat, eller lastes opp noe sted --
# den er allerede lagt til i .gitignore slik at den ikke havner i versjonskontroll.

# --- AI-veilederen (FEM) ---
# API-nøkkel fra console.anthropic.com (Settings -> API Keys).
ANTHROPIC_API_KEY=

# Hvilken modell FEM bruker som standard. Kan senere overstyres fra
# administrasjonspanelet (Dokument 09 §21.1) uten ny utrulling.
ANTHROPIC_MODEL=claude-haiku-4-5

# Anti-misbruk-tak, jf. Forretnings- og prismodell §3 (besluttet).
AI_MAX_QUESTIONS_PER_SESSION=100
AI_GLOBAL_QUESTION_CAP=10000

# --- Nettstedets egen adresse ---
# Brukes bl.a. til WebAuthn/passkey-oppsett (seksjon 10.2) og delefunksjon.
# Sett til http://localhost:3000 under lokal utvikling/testing.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Admin-innlogging (passkey) ---
# "Relying party"-navn vist i Face ID/Touch ID-dialogen.
ADMIN_PASSKEY_RP_NAME=FemFaktorer Admin

# Hemmelig nøkkel brukt til å signere admin-innloggingsøkten (cookie).
# Generer en tilfeldig lang streng selv, f.eks. med:  openssl rand -hex 32
ADMIN_SESSION_SECRET=

# --- Analyse (fylles inn nærmere lansering, se seksjon 8 i oppgavelisten) ---
# PLAUSIBLE_DOMAIN=femfaktorer.no

# --- Konto: lagre fullversjon-resultat på tvers av enheter (v2.4) ---
# Innlogging med e-post + engangskode -- ingen passord. Krever Netlify Blobs
# (innebygd, ingen egen database) + Resend (e-postutsending).

# "Pepper" brukt til å hashe engangskodene før de lagres -- ALDRI koden selv
# i klartekst. Generer selv, f.eks. med:  openssl rand -hex 32
ACCOUNT_OTP_PEPPER=

# API-nøkkel fra resend.com (opprett gratis konto -> API Keys).
RESEND_API_KEY=

# Avsenderadresse for innloggingskoder, f.eks. "FemFaktorer <innlogging@femfaktorer.no>".
# VIKTIG: uten et VERIFISERT domene i Resend kan e-post kun sendes til
# adressen som står på selve Resend-kontoen din (fungerer for egen testing,
# ikke for andre brukere før et domene er verifisert -- se lib/account/email.ts).
RESEND_FROM_ADDRESS=

# Valgfritt: kun nødvendig hvis Netlify Blobs IKKE får site-kontekst
# automatisk (skjer normalt bare hvis du kjører appen utenfor Netlifys egen
# kjøremiljø/CLI). Finnes under Prosjektkonfigurasjon -> Generelt i Netlify,
# og et Personal Access Token under brukerinnstillingene dine.
NETLIFY_BLOBS_SITE_ID=
NETLIFY_BLOBS_TOKEN=
