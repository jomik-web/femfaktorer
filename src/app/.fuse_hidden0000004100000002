@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  html {
    @apply scroll-smooth;
  }

  body {
    @apply bg-white text-ink dark:bg-ink dark:text-warmgray;
    font-feature-settings: "cv11", "ss01";
  }

  /* WCAG 2.2 AA: synlig fokusmarkør på alle interaktive elementer (Dokument 02 §20) */
  :focus-visible {
    @apply outline outline-2 outline-offset-2 outline-teal;
  }

  /* Respekter redusert bevegelse (Dokument 02 §6.5) */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }
}

/*
 * PDF/utskrift av resultatsiden (v2.3, produkteiers ønske om "pdf med
 * resultatene på den fulle testen"). Ingen ny avhengighet -- bruker nettleserens
 * innebygde "Skriv ut -> Lagre som PDF". Tvinger lyst fargeskjema uavhengig av
 * systeminnstilling for mørk modus (darkMode: "media" i tailwind.config.ts),
 * siden `dark:`-varianter ellers kan slå inn under utskrift på en enhet som
 * står i mørk modus, og gi hvit tekst på hvitt papir.
 */
@media print {
  html,
  body {
    background: #ffffff !important;
    color: #0d3340 !important;
  }

  /* Unngå at en fasettboks eller kombinasjonsboks kappes midt over et sideskift. */
  section,
  article {
    break-inside: avoid;
  }
}
